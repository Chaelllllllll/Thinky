{
  "version": 2,
  "functions": {
    "api/[...slug].js": { "maxDuration": 60 }
  },
  "routes": [
    { "src": "^/api/(.*)$", "dest": "/api/[...slug].js" },
    { "src": "^/ads\\.txt/?$", "dest": "/public/ads.txt" },
    { "src": "^/sitemap\\.xml/?$", "dest": "/public/sitemap.xml" },
    { "src": "^/robots\\.txt/?$", "dest": "/public/robots.txt" },
    { "src": "^/sitemap/?$", "dest": "/public/sitemap.xml" },
    { "src": "^/(js|css|images|auth|fonts)/(.*)$", "dest": "/public/$1/$2" },
    { "src": "^/$", "dest": "/public/index.html" },
    { "src": "^/([^\\.]+)$", "dest": "/public/$1.html" },
    { "src": "^/(.*)$", "dest": "/public/$1" }
  ]
}


